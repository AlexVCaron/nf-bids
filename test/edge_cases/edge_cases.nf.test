nextflow_process {

    name "Test Edge Cases for Closure-Based Channel Operators"
    script "test/edge_cases/test_edge_cases.nf"

    test("groupTupleBy handles very large items") {
        
        when {
            process {
                """
                input:
                ch_large
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Large item test: PASSED")
            assert process.stdout.contains("Memory usage: OK")
        }
    }

    test("groupTupleBy handles many small items (100k+)") {
        
        when {
            process {
                """
                input:
                ch_many_small
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Many small items test: PASSED")
            assert process.stdout.contains("Items processed: 100000")
        }
    }

    test("groupTupleBy handles complex nested structures") {
        
        when {
            process {
                """
                input:
                ch_nested
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Nested structure test: PASSED")
        }
    }

    test("groupTupleBy handles closure accessing non-existent field gracefully") {
        
        when {
            process {
                """
                input:
                ch_missing_field
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Missing field handled: PASSED")
        }
    }

    test("groupTupleBy allows closure modifying items") {
        
        when {
            process {
                """
                input:
                ch_modify
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Modification test: PASSED")
        }
    }

    test("joinBy handles very large items") {
        
        when {
            process {
                """
                input:
                ch_large_left
                ch_large_right
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Large join test: PASSED")
        }
    }

    test("joinBy handles many small items (100k+)") {
        
        when {
            process {
                """
                input:
                ch_many_left
                ch_many_right
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Many join items test: PASSED")
        }
    }

    test("combineBy handles very large cartesian product") {
        
        when {
            process {
                """
                input:
                ch_combine_left
                ch_combine_right
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Large combine test: PASSED")
        }
    }

    test("combineBy handles complex filter predicates") {
        
        when {
            process {
                """
                input:
                ch_filter_test
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Complex filter test: PASSED")
        }
    }

    test("groupTupleBy handles concurrent execution") {
        
        when {
            process {
                """
                input:
                ch_concurrent
                """
            }
        }

        then {
            assert process.success
            assert process.stdout.contains("Concurrent test: PASSED")
            assert process.stdout.contains("No race conditions detected")
        }
    }
}
