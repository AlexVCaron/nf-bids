nextflow_pipeline {

    name "Path Type Validation"
    script "./test_path_types.nf"

    test("fromBIDS emits Path-compatible values") {
        when {
            params {
                bids_dir = "${baseDir}/test/data/bids-examples/asl001"
                config = "${baseDir}/test/configs/config_asl.yaml"
                libbids_sh = "${baseDir}/libBIDS.sh/libBIDS.sh"
            }
        }
        then {
            assert workflow.success
        }
    }
}
