nextflow_workflow {

    name "Plugin Comparison: Mixed Sets"
    script "./main.nf"
    workflow "main_workflow"

    test("qmri_mpm - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/bids-examples/qmri_mpm"
                config = "${baseDir}/validation/configs/config_mpm.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            // Serialize to normalise types, then strip the machine-specific bidsParentDir field.
            // NIfTI files (.nii.gz / .nii) and all other file types are kept as their relative
            // path strings so that snapshot comparison is machine-independent and never triggers
            // gzip decompression on the dummy stub files used in the test datasets.
            def parsed = new groovy.json.JsonSlurper().parseText(groovy.json.JsonOutput.toJson(results))
            def snapshot_data = parsed.collect { item ->
                item.collect { e ->
                    (e instanceof Map && e.containsKey('bidsParentDir'))
                        ? e.findAll { k, v -> k != 'bidsParentDir' }
                        : e
                }
            }
            assert snapshot(snapshot_data).match()
        }
    }
}
