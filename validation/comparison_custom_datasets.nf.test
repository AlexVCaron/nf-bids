nextflow_workflow {

    name "Plugin Comparison: Custom Datasets"
    script "./main.nf"
    workflow "main_workflow"

    test("ds-dwi - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/custom/ds-dwi"
                config = "${baseDir}/validation/configs/config_dwi.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            def mkPath = { String p -> path(p) }
            assert snapshot(sanitizeBidsResults(results, mkPath)).match()
        }
    }

    test("ds-dwi2 - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/custom/ds-dwi2"
                config = "${baseDir}/validation/configs/config_dwi.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            def mkPath = { String p -> path(p) }
            assert snapshot(sanitizeBidsResults(results, mkPath)).match()
        }
    }

    test("ds-dwi3 - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/custom/ds-dwi3"
                config = "${baseDir}/validation/configs/config_dwi.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            def mkPath = { String p -> path(p) }
            assert snapshot(sanitizeBidsResults(results, mkPath)).match()
        }
    }

    test("ds-dwi4 - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/custom/ds-dwi4"
                config = "${baseDir}/validation/configs/config_dwi.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            def mkPath = { String p -> path(p) }
            assert snapshot(sanitizeBidsResults(results, mkPath)).match()
        }
    }

    test("ds-mrs_fmrs - Plugin output") {
        when {
            params {
                bids_dir = "${baseDir}/validation/data/custom/ds-mrs_fmrs"
                config = "${baseDir}/validation/configs/config_mrs.yaml"
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bids_channel
            def results = workflow.out.bids_channel.collect()
            def mkPath = { String p -> path(p) }
            assert snapshot(sanitizeBidsResults(results, mkPath)).match()
